
{
  "entities": {
    "Template": {
      "title": "Template",
      "description": "Represents a reusable template for creating new items like projects or tasks.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the template."
        },
        "description": {
            "type": "string",
            "description": "A short description of what the template is for."
        },
        "type": {
          "type": "string",
          "enum": ["Project", "TaskList", "Document", "Report"],
          "description": "The type of entity this template creates."
        },
        "data": {
          "type": "array",
          "description": "An array of content blocks that define the template structure.",
           "items": {
            "type": "object"
          }
        },
        "version": {
          "type": "number",
          "description": "The version of the template."
        },
        "clientId": {
          "type": "string",
          "description": "The ID of the client this template belongs to."
        },
        "createdBy": {
          "type": "string"
        },
        "createdOn": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "type", "data", "version", "createdBy", "createdOn", "clientId"]
    },
    "Client": {
      "title": "Client",
      "description": "Represents a client company or organization.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the client."
        },
        "contactEmail": {
          "type": "string",
          "format": "email",
          "description": "The primary email for the client."
        },
        "status": {
          "type": "string",
          "enum": ["Active", "Inactive", "Onboarding"]
        },
        "createdOn": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "status", "createdOn"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "URL of the user's profile picture."
        }
      },
      "required": ["displayName", "email"]
    },
    "AiSuggestion": {
      "title": "AI Suggestion",
      "description": "Represents an AI-generated suggestion.",
      "type": "object",
      "properties": {
        "suggestedActions": {
          "type": "string",
          "description": "A list of suggested actions for the client, prioritized by urgency and impact."
        },
        "pendingDeadlines": {
          "type": "string",
          "description": "A summary of upcoming deadlines and their potential impact."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the suggestion was created."
        }
      },
      "required": ["suggestedActions", "pendingDeadlines", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "Represents a project.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the project."
        },
        "createdBy": {
          "type": "string",
          "description": "The ID of the user who created the project."
        },
        "createdOn": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the project was created."
        },
        "status": {
          "type": "string",
          "enum": ["Planning", "In Progress", "On Hold", "Completed"]
        },
        "deadline": {
          "type": "string",
          "format": "date",
          "description": "The project deadline."
        },
        "clientId": {
          "type": "string"
        }
      },
      "required": ["name", "createdBy", "createdOn", "status", "deadline"]
    },
    "Task": {
      "title": "Task",
      "description": "Represents a single task or to-do item.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the task."
        },
        "description": {
            "type": "string",
            "description": "A detailed description of the task."
        },
        "project": {
            "type": "string",
            "description": "The ID of the project this task belongs to."
        },
        "status": {
          "type": "string",
          "enum": ["To Do", "In Progress", "Done", "Cancelled"]
        },
        "subtasks": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "text": { "type": "string" },
                    "completed": { "type": "boolean" }
                }
            },
            "description": "A list of subtasks."
        },
        "createdBy": {
          "type": "string",
          "description": "The ID of the user who created the task."
        },
        "createdOn": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the task was created."
        },
        "deadline": {
          "type": "string",
          "format": "date",
          "description": "The task deadline."
        },
        "assignees": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "clientId": {
            "type": "string"
        }
      },
      "required": ["title", "status", "createdBy", "createdOn", "clientId"]
    },
    "KnowledgeArticle": {
      "title": "Knowledge Article",
      "description": "Represents an article in the knowledge base.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Published", "Archived"] },
        "createdBy": { "type": "string" },
        "createdOn": { "type": "string", "format": "date-time" },
        "updatedOn": { "type": "string", "format": "date-time" },
        "clientId": { "type": "string" }
      },
      "required": ["title", "content", "status", "createdBy", "createdOn", "clientId"]
    },
    "Experiment": {
      "title": "Experiment",
      "description": "Represents an experiment.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "hypothesis": { "type": "string" },
        "status": { "type": "string", "enum": ["Planning", "Running", "Completed", "Cancelled"] },
        "createdBy": { "type": "string" },
        "createdOn": { "type": "string", "format": "date-time" },
        "clientId": { "type": "string" }
      },
      "required": ["name", "hypothesis", "status", "createdBy", "createdOn", "clientId"]
    },
    "Invoice": {
        "title": "Invoice",
        "description": "Represents a billing invoice.",
        "type": "object",
        "properties": {
            "invoiceId": { "type": "string", "description": "The unique identifier for the invoice (e.g., INV-2024-001)." },
            "title": { "type": "string", "description": "The title of the invoice." },
            "description": { "type": "string", "description": "A description of the invoice." },
            "amount": { "type": "number", "description": "The total amount due." },
            "currency": { "type": "string", "description": "The currency of the amount.", "enum": ["USD", "EUR", "GBP", "JPY", "NRS"] },
            "dueDate": { "type": "string", "format": "date", "description": "The date the invoice is due." },
            "status": { "type": "string", "enum": ["Paid", "Due", "Overdue"], "description": "The current status of the invoice." },
            "clientName": { "type": "string", "description": "The name of the client being invoiced." },
            "createdOn": { "type": "string", "format": "date-time" },
            "updatedOn": { "type": "string", "format": "date-time" },
            "clientId": { "type": "string" }
        },
        "required": ["invoiceId", "title", "amount", "currency", "dueDate", "status", "clientName", "createdOn", "clientId"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Represents a detailed contact profile.",
      "type": "object",
      "properties": {
        "name": {
          "type": "object",
          "properties": {
            "firstName": { "type": "string" },
            "middleName": { "type": "string" },
            "lastName": { "type": "string" }
          }
        },
        "role": { "type": "string" },
        "organization": { "type": "string" },
        "emails": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "email": { "type": "string", "format": "email" }
            }
          }
        },
        "phoneNumbers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "phone": { "type": "string" }
            }
          }
        },
        "addresses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "street": { "type": "string" },
              "city": { "type": "string" },
              "state": { "type": "string" },
              "zip": { "type": "string" },
              "country": { "type": "string" }
            }
          }
        },
        "socialProfiles": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "messaging": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "address": { "type": "string" }
            }
          }
        },
        "importantDates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "date": { "type": "string", "format": "date" }
            }
          }
        },
        "notes": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "createdOn": { "type": "string", "format": "date-time" },
        "updatedOn": { "type": "string", "format": "date-time" },
        "clientId": { "type": "string" }
      },
      "required": ["name", "clientId"]
    },
    "Goal": {
        "title": "Goal",
        "description": "Represents a goal or milestone.",
        "type": "object",
        "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "targetDate": { "type": "string", "format": "date" },
            "status": { "type": "string", "enum": ["Not Started", "In Progress", "Completed", "At Risk"] },
            "clientId": { "type": "string" }
        },
        "required": ["title", "targetDate", "status", "clientId"]
    },
    "Report": {
        "title": "Report",
        "description": "Represents a report.",
        "type": "object",
        "properties": {
            "title": { "type": "string" },
            "summary": { "type": "string" },
            "generatedOn": { "type": "string", "format": "date-time" },
            "clientId": { "type": "string" },
            "type": { "type": "string", "enum": ["client", "project", "manual"]},
            "dateRange": {
                "type": "object",
                "properties": {
                    "from": { "type": "string", "format": "date-time" },
                    "to": { "type": "string", "format": "date-time" }
                }
            },
            "projectId": { "type": "string" }
        },
        "required": ["title", "generatedOn", "clientId"]
    },
    "Feedback": {
        "title": "Feedback",
        "description": "Represents client feedback.",
        "type": "object",
        "properties": {
            "title": { "type": "string" },
            "comment": { "type": "string" },
            "submittedBy": { "type": "string" },
            "submittedOn": { "type": "string", "format": "date-time" },
            "clientId": { "type": "string" }
        },
        "required": ["title", "comment", "submittedBy", "submittedOn", "clientId"]
    },
    "Discussion": {
        "title": "Discussion",
        "description": "Represents a discussion thread.",
        "type": "object",
        "properties": {
            "title": { "type": "string" },
            "createdBy": { "type": "string" },
            "createdOn": { "type": "string", "format": "date-time" },
            "clientId": { "type": "string" }
        },
        "required": ["title", "createdBy", "createdOn", "clientId"]
    },
    "Document": {
      "title": "Document",
      "description": "Represents a file in the document repository.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "version": { "type": "string" },
        "status": { "type": "string", "enum": ["Signed", "Approved", "In Review", "Archived"] },
        "fileType": { "type": "string", "description": "The MIME type of the file." },
        "size": { "type": "number", "description": "The size of the file in bytes." },
        "uploadedBy": { "type": "string", "description": "The ID of the user who uploaded the file." },
        "notes": { "type": "string", "description": "Notes or comments about the file." },
        "createdOn": { "type": "string", "format": "date-time" },
        "updatedOn": { "type": "string", "format": "date-time" },
        "clientId": { "type": "string" }
      },
      "required": ["name", "url", "status", "createdOn", "clientId"]
    },
    "Activity": {
        "title": "Activity",
        "description": "Represents a log of work or an update.",
        "type": "object",
        "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "results": { "type": "string" },
            "links": {
                "type": "array",
                "items": { "type": "string", "format": "uri" }
            },
            "files": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "name": { "type": "string" },
                        "url": { "type": "string", "format": "uri" }
                    }
                }
            },
            "projectId": { "type": "string" },
            "clientId": { "type": "string" },
            "createdBy": { "type": "string" },
            "createdOn": { "type": "string", "format": "date-time" }
        },
        "required": ["title", "clientId", "createdBy", "createdOn"]
    }
  },
  "firestore": {
    "/templates/{templateId}": {
        "schema": { "$ref": "#/backend/entities/Template" },
        "description": "Stores reusable templates."
    },
    "/clients/{clientId}": {
      "schema": { "$ref": "#/backend/entities/Client" },
      "description": "Stores client information."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Stores public information about a user."
    },
    "/ai_suggestions/{suggestionId}": {
      "schema": { "$ref": "#/backend/entities/AiSuggestion" },
      "description": "Stores AI generated suggestions."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/backend/entities/Project" },
      "description": "Stores project data."
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/backend/entities/Task" },
      "description": "Stores individual tasks for all projects."
    },
    "/knowledge/{articleId}": {
        "schema": { "$ref": "#/backend/entities/KnowledgeArticle" },
        "description": "Stores knowledge base articles."
    },
    "/experiments/{experimentId}": {
        "schema": { "$ref": "#/backend/entities/Experiment" },
        "description": "Stores experiment data."
    },
    "/invoices/{invoiceId}": {
        "schema": { "$ref": "#/backend/entities/Invoice" },
        "description": "Stores billing invoices."
    },
    "/contacts/{contactId}": {
      "schema": { "$ref": "#/backend/entities/Contact" },
      "description": "Stores contact information."
    },
    "/goals/{goalId}": {
        "schema": { "$ref": "#/backend/entities/Goal" },
        "description": "Stores goals and milestones."
    },
    "/reports/{reportId}": {
        "schema": { "$ref": "#/backend/entities/Report" },
        "description": "Stores reports."
    },
    "/feedback/{feedbackId}": {
        "schema": { "$ref": "#/backend/entities/Feedback" },
        "description": "Stores client feedback."
    },
    "/discussions/{discussionId}": {
        "schema": { "$ref": "#/backend/entities/Discussion" },
        "description": "Stores discussion threads."
    },
    "/documents/{documentId}": {
        "schema": { "$ref": "#/backend/entities/Document" },
        "description": "Stores documents and files."
    },
    "/activities/{activityId}": {
        "schema": { "$ref": "#/backend/entities/Activity" },
        "description": "Stores activity logs."
    }
  }
}
